# App
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kun-bookshop

# JWT
JWT_SECRET=generate_with_node_-e_console.log(require("crypto").randomBytes(64).toString("hex"))

# URLs
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# Email settings
# For production only (leave empty in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Kun Bookshop <your_email@gmail.com>"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx