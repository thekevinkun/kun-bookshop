# App
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kun-bookshop

# JWT
JWT_SECRET=generate_with_node_-e_console.log(require("crypto").randomBytes(64).toString("hex"))

# URLs
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# Email settings
RESEND_API_KEY=re_*******
RESEND_TEST_EMAIL=youremail@gmail.com

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# KUN AI Chatbot — controls which mode the chatbot runs in
# mock = scripted responses, zero API cost (use this during development)
# openai = real OpenAI gpt-4o-mini with tool calling
CHAT_MODE=mock

# Your OpenAI API key — only read in openai mode, ignored in mock mode
OPENAI_API_KEY=sk-your-key-here