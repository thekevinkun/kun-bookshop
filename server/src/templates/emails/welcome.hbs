<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Kun Bookshop</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #0f172a;
        font-family: Arial, sans-serif;
      }
      .container {
        max-width: 560px;
        margin: 40px auto;
        background-color: #1e293b;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        background-color: #14b8a6;
        padding: 32px;
        text-align: center;
      }
      .header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 24px;
      }
      .body {
        padding: 32px;
        color: #f8fafc;
      }
      .body p {
        line-height: 1.6;
        color: #cbd5e1;
      }
      .feature {
        background-color: #0f172a;
        border-radius: 8px;
        padding: 16px;
        margin: 12px 0;
      }
      .feature p {
        margin: 0;
        color: #cbd5e1;
      }
      .btn {
        display: inline-block;
        margin: 24px 0;
        padding: 14px 32px;
        background-color: #14b8a6;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
        font-size: 16px;
      }
      .footer {
        padding: 16px 32px;
        text-align: center;
        color: #475569;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>📚 Kun Bookshop</h1>
      </div>
      <div class="body">
        <!-- {{ firstName }} is replaced with the user's actual first name -->
        <h2 style="color: #f8fafc;">Welcome, {{firstName}}! 🎉</h2>
        <p>Your account is now verified and ready to go. Here's what you can do
          with Kun Bookshop:</p>

        <div class="feature">
          <p>📖
            <strong>Browse</strong>
            thousands of digital books in PDF and ePub format</p>
        </div>
        <div class="feature">
          <p>🛒 <strong>Purchase</strong> books securely with Stripe</p>
        </div>
        <div class="feature">
          <p>📚 <strong>Build</strong> your personal digital library</p>
        </div>
        <div class="feature">
          <p>⭐ <strong>Review</strong> books and help other readers</p>
        </div>

        <!-- {{ shopUrl }} is replaced with the frontend URL from .env -->
        <a href="{{shopUrl}}" class="btn">Start Browsing Books</a>

        <p>Happy reading! 📚</p>
      </div>
      <div class="footer">
        <p>© 2026 Kun Bookshop. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>