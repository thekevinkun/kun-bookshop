<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password changed</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #0f172a;
        font-family: Arial, sans-serif;
      }
      .container {
        max-width: 560px;
        margin: 40px auto;
        background-color: #1e293b;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        background-color: #10b981;
        padding: 32px;
        text-align: center;
      }
      .header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 24px;
      }
      .body {
        padding: 32px;
        color: #f8fafc;
      }
      .body p {
        line-height: 1.6;
        color: #cbd5e1;
      }
      .warning {
        background-color: #0f172a;
        border-left: 4px solid #ef4444;
        padding: 12px 16px;
        border-radius: 4px;
        margin: 16px 0;
      }
      .warning p {
        margin: 0;
        color: #ef4444;
        font-size: 14px;
      }
      .btn {
        display: inline-block;
        margin: 24px 0;
        padding: 14px 32px;
        background-color: #10b981;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
        font-size: 16px;
      }
      .footer {
        padding: 16px 32px;
        text-align: center;
        color: #475569;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>📚 Kun Bookshop</h1>
      </div>
      <div class="body">
        <h2 style="color: #f8fafc;">Your password was changed ✅</h2>
        <p>This is a confirmation that the password for your Kun Bookshop
          account was successfully changed.</p>

        <div class="warning">
          <p>🚨 If you did NOT make this change, please contact our support team
            immediately.</p>
        </div>

        <!-- {{ supportUrl }} is replaced with the contact/support page URL -->
        <a href="{{supportUrl}}" class="btn">Contact Support</a>

        <p>If you made this change yourself, no further action is needed.</p>
      </div>
      <div class="footer">
        <p>© 2026 Kun Bookshop. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>