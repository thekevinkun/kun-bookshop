<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password changed</title>
    <style>
      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background-color: #0f172a;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background: #1e293b;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: linear-gradient(135deg, #0a1628 0%, #1e3a5f 100%);
        color: white;
        padding: 30px 20px;
        text-align: center;
      }
      .logo-image_wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .logo-image_wrapper .logo-image {
        width: 38px;
        height: 38px;
        object-fit: cover;
      }
      .logo-image_wrapper .logo-image_text {
        font-family: "Cinzel", serif;
        font-size: 28px;
        font-weight: 500;
        background: linear-gradient(
          135deg,
          #f8fafc 0%,
          #e6be77 50%,
          #f8fafc 100%
        );
        background-size: 200% 200%;
        background-position: left;

        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .content {
        padding: 40px 30px;
        color: #f8fafc;
        line-height: 1.6;
        font-size: 16px;
      }
      .content h1 {
        margin: 0;
        color: #e6be77;
        font-size: 22px;
        font-weight: 500;
      }
      .warning {
        background-color: #0f172a;
        border-left: 4px solid #ef4444;
        padding: 12px 16px;
        border-radius: 4px;
        margin: 16px 0;
      }
      .warning p {
        margin: 0;
        color: #ef4444;
        font-size: 14px;
      }
      .btn {
        display: inline-block;
        background: #e6be77;
        color: #000 !important;
        padding: 14px 32px;
        text-decoration: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        margin: 24px 0 8px;
      }
      .footer {
        background: rgba(10, 22, 40, 0.5);
        padding: 20px;
        text-align: center;
        font-size: 13px;
        color: #d1d1d1;
      }
      .footer a {
        color: #e6be77;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div
          to="/"
          class="logo-image_wrapper"
        >
          <img 
            src="{{logoUrl}}"
            alt="Logo"
            class="logo-image"
          />
          <span class="logo-image_text">
            un <span class="logo-image_span">Bookshop</span>
          </span>
        </div>
      </div>
      <div class="content">
        <h1>Your password was changed!</h1>
        <p>This is a confirmation that the password for your Kun Bookshop
          account was successfully changed.</p>

        <div class="warning">
          <p>🚨 If you did NOT make this change, please contact our support team
            immediately.</p>
        </div>

        <!-- {{ supportUrl }} is replaced with the contact/support page URL -->
        <a href="{{supportUrl}}" class="btn">Contact Support</a>

        <p>If you made this change yourself, no further action is needed.</p>
      </div>
      <div class="footer">
        <p>© 2026 Kun Bookshop. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>