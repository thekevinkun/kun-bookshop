<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify your email</title>
    <style>
      /* Simple inline-friendly styles — email clients don't support external CSS */
      body {
        margin: 0;
        padding: 0;
        background-color: #0f172a;
        font-family: Arial, sans-serif;
      }
      .container {
        max-width: 560px;
        margin: 40px auto;
        background-color: #1e293b;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        background-color: #14b8a6;
        padding: 32px;
        text-align: center;
      }
      .header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 24px;
      }
      .body {
        padding: 32px;
        color: #f8fafc;
      }
      .body p {
        line-height: 1.6;
        color: #cbd5e1;
      }
      .btn {
        display: inline-block;
        margin: 24px 0;
        padding: 14px 32px;
        background-color: #14b8a6;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
        font-size: 16px;
      }
      .footer {
        padding: 16px 32px;
        text-align: center;
        color: #475569;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>📚 Kun Bookshop</h1>
      </div>
      <div class="body">
        <h2 style="color: #f8fafc;">Verify your email address</h2>
        <p>Thanks for signing up! Click the button below to verify your email
          address and activate your account.</p>
        <p>This link expires in <strong>24 hours</strong>.</p>

        <!-- {{ verificationUrl }} is replaced by Handlebars with the real URL -->
        <a href="{{verificationUrl}}" class="btn">Verify My Email</a>

        <p>If the button doesn't work, copy and paste this link into your
          browser:</p>
        <p
          style="word-break: break-all; color: #14b8a6;"
        >{{verificationUrl}}</p>
        <p>If you didn't create an account, you can safely ignore this email.</p>
      </div>
      <div class="footer">
        <p>© 2025 Kun Bookshop. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>