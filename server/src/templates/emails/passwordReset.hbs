<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password</title>
  </head>
  <body style="margin:0;padding:0;background-color:#0f172a;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0f172a;">
      <tr>
        <td align="center" style="padding:20px 0;">

          <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background-color:#1e293b;border-radius:12px;overflow:hidden;">

            <!-- Header -->
            <tr>
              <td style="background-color:#0d1f38;padding:30px 20px;text-align:center;">
                <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
                  <tr>
                    <td style="vertical-align:middle;padding-right:8px;">
                      <img src="{{logoUrl}}" alt="Logo" width="38" height="38" style="display:block;width:38px;height:38px;object-fit:cover;" />
                    </td>
                    <td style="vertical-align:middle;">
                      <span style="font-size:28px;font-weight:500;color:#e6be77;font-family:Georgia,serif;">un Bookshop</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:40px 30px;color:#f8fafc;font-size:16px;line-height:1.6;">

                <p style="margin:0 0 16px;color:#e6be77;font-size:22px;font-weight:500;">Reset your password</p>

                <p style="margin:0 0 16px;color:#f8fafc;">We received a request to reset the password for your Kun Bookshop account.</p>
                <p style="margin:0 0 16px;color:#f8fafc;">Click the button below to set a new password:</p>

                <!-- CTA button -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:24px 0 8px;">
                  <tr>
                    <td>
                      <a href="{{resetUrl}}" style="display:inline-block;background-color:#ef4444;color:#ffffff;padding:14px 32px;text-decoration:none;border-radius:8px;font-size:16px;font-weight:600;">Reset My Password</a>
                    </td>
                  </tr>
                </table>

                <!-- Warning box -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:16px 0;">
                  <tr>
                    <td style="background-color:#0f172a;border-left:4px solid #f59e0b;border-radius:4px;padding:12px 16px;">
                      <p style="margin:0;color:#f59e0b;font-size:14px;">⚠️ This link expires in <strong>{{expiresIn}}</strong>. Do not share it with anyone.</p>
                    </td>
                  </tr>
                </table>

                <p style="margin:0 0 8px;color:#f8fafc;">If the button doesn't work, copy and paste this link into your browser:</p>
                <p style="margin:0 0 16px;word-break:break-all;color:#ef4444;">{{resetUrl}}</p>
                <p style="margin:0;color:#f8fafc;">If you didn't request a password reset, you can safely ignore this email. Your password will not change.</p>

              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color:#0a1628;padding:20px;text-align:center;font-size:13px;color:#d1d1d1;">
                <p style="margin:0 0 8px;">© 2026 Kun Bookshop. All rights reserved.</p>
                <p style="margin:0;"><a href="{{supportUrl}}" style="color:#e6be77;text-decoration:none;">Contact Support</a></p>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>
