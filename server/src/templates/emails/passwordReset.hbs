<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password</title>
    <style>
      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background-color: #0f172a;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background: #1e293b;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: linear-gradient(135deg, #0a1628 0%, #1e3a5f 100%);
        color: white;
        padding: 30px 20px;
        text-align: center;
      }
      .logo-image_wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .logo-image_wrapper .logo-image {
        width: 38px;
        height: 38px;
        object-fit: cover;
      }
      .logo-image_wrapper .logo-image_text {
        font-family: "Cinzel", serif;
        font-size: 28px;
        font-weight: 500;
        background: linear-gradient(
          135deg,
          #f8fafc 0%,
          #e6be77 50%,
          #f8fafc 100%
        );
        background-size: 200% 200%;
        background-position: left;

        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .content {
        padding: 40px 30px;
        color: #f8fafc;
        line-height: 1.6;
        font-size: 16px;
      }
      .content h1 {
        margin: 0;
        color: #e6be77;
        font-size: 22px;
        font-weight: 500;
      }
      .warning {
        background-color: #0f172a;
        border-left: 4px solid #f59e0b;
        padding: 12px 16px;
        border-radius: 4px;
        margin: 16px 0;
      }
      .warning p {
        margin: 0;
        color: #f59e0b;
        font-size: 14px;
      }
      .btn {
        display: inline-block;
        margin: 24px 0 8px;
        padding: 14px 32px;
        background-color: #ef4444;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
      }
      .footer {
        background: rgba(10, 22, 40, 0.5);
        padding: 20px;
        text-align: center;
        font-size: 13px;
        color: #d1d1d1;
      }
      .footer a {
        color: #e6be77;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div
          to="/"
          class="logo-image_wrapper"
        >
          <img 
            src="{{logoUrl}}"
            alt="Logo"
            class="logo-image"
          />
          <span class="logo-image_text">
            un <span class="logo-image_span">Bookshop</span>
          </span>
        </div>
      </div>

      <div class="content">
        <h1>Reset your password</h1>
        <p>We received a request to reset the password for your Kun Bookshop
          account.</p>
        <p>Click the button below to set a new password:</p>

        <!-- {{ resetUrl }} is replaced with the full reset link including the token -->
        <a href="{{resetUrl}}" class="btn">Reset My Password</a>

        <div class="warning">
          <!-- {{ expiresIn }} is replaced with '1 hour' from the email service -->
          <p>⚠️ This link expires in
            <strong>{{expiresIn}}</strong>. Do not share it with anyone.</p>
        </div>

        <p>If the button doesn't work, copy and paste this link into your
          browser:</p>
        <p style="word-break: break-all; color: #ef4444;">{{resetUrl}}</p>
        <p>If you didn't request a password reset, you can safely ignore this
          email. Your password will not change.</p>
      </div>
      <div class="footer">
        <p>© 2026 Kun Bookshop. All rights reserved.</p>
        <p>
          <a href="{{supportUrl}}">Contact Support</a>
        </p>
      </div>
    </div>
  </body>
</html>