<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #0f172a;
        font-family: Arial, sans-serif;
      }
      .container {
        max-width: 560px;
        margin: 40px auto;
        background-color: #1e293b;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        background-color: #ef4444;
        padding: 32px;
        text-align: center;
      }
      .header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 24px;
      }
      .body {
        padding: 32px;
        color: #f8fafc;
      }
      .body p {
        line-height: 1.6;
        color: #cbd5e1;
      }
      .warning {
        background-color: #0f172a;
        border-left: 4px solid #f59e0b;
        padding: 12px 16px;
        border-radius: 4px;
        margin: 16px 0;
      }
      .warning p {
        margin: 0;
        color: #f59e0b;
        font-size: 14px;
      }
      .btn {
        display: inline-block;
        margin: 24px 0;
        padding: 14px 32px;
        background-color: #ef4444;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
        font-size: 16px;
      }
      .footer {
        padding: 16px 32px;
        text-align: center;
        color: #475569;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>📚 Kun Bookshop</h1>
      </div>
      <div class="body">
        <h2 style="color: #f8fafc;">Reset your password</h2>
        <p>We received a request to reset the password for your Kun Bookshop
          account.</p>
        <p>Click the button below to set a new password:</p>

        <!-- {{ resetUrl }} is replaced with the full reset link including the token -->
        <a href="{{resetUrl}}" class="btn">Reset My Password</a>

        <div class="warning">
          <!-- {{ expiresIn }} is replaced with '1 hour' from the email service -->
          <p>⚠️ This link expires in
            <strong>{{expiresIn}}</strong>. Do not share it with anyone.</p>
        </div>

        <p>If the button doesn't work, copy and paste this link into your
          browser:</p>
        <p style="word-break: break-all; color: #ef4444;">{{resetUrl}}</p>
        <p>If you didn't request a password reset, you can safely ignore this
          email. Your password will not change.</p>
      </div>
      <div class="footer">
        <p>© 2025 Kun Bookshop. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>