<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Confirmed</title>
  </head>
  <body
    style="margin:0;padding:0;background-color:#0f172a;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;"
  >

    <!-- Outer wrapper -->
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      border="0"
      style="background-color:#0f172a;"
    >
      <tr>
        <td align="center" style="padding:20px 0;">

          <!-- Main container -->
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="max-width:600px;width:100%;background-color:#1e293b;border-radius:12px;overflow:hidden;"
          >

            <!-- Header -->
            <tr>
              <td
                style="background-color:#0d1f38;padding:30px 20px;text-align:center;"
              >
                <!-- Logo row using table instead of flex -->
                <table
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="margin:0 auto;"
                >
                  <tr>
                    <td style="vertical-align:middle;padding-right:8px;">
                      <!-- Logo image -->
                      <img
                        src="{{logoUrl}}"
                        alt="Logo"
                        width="38"
                        height="38"
                        style="display:block;width:38px;height:38px;object-fit:cover;"
                      />
                    </td>
                    <td style="vertical-align:middle;">
                      <!-- Logo text — plain gold color, no gradient (Gmail strips it) -->
                      <span
                        style="font-size:28px;font-weight:500;color:#e6be77;font-family:Georgia,serif;"
                      >un Bookshop</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td
                style="padding:40px 30px;color:#f8fafc;font-size:16px;line-height:1.6;"
              >

                <!-- Title -->
                <p
                  style="margin:0 0 24px;color:#e6be77;font-size:22px;font-weight:500;"
                >Your order is confirmed!</p>

                <!-- Order number badge -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="margin-bottom:24px;"
                >
                  <tr>
                    <td
                      style="background-color:#2d3f55;border:1px solid #93a4b5;border-radius:8px;padding:12px 20px;text-align:center;"
                    >
                      <span
                        style="font-size:14px;color:#d1d1d1;display:block;"
                      >Order Number</span>
                      <strong
                        style="font-size:20px;color:#e6be77;display:block;margin-top:2px;"
                      >{{orderNumber}}</strong>
                    </td>
                  </tr>
                </table>

                <!-- Intro text -->
                <p style="margin:0 0 24px;color:#f8fafc;">
                  Thank you for your purchase! Your books are now available in
                  your library and ready to read or download anytime.
                </p>

                <!-- Section title -->
                <p
                  style="font-size:18px;font-weight:600;color:#f8fafc;margin:0 0 16px;padding-bottom:8px;border-bottom:2px solid #d1d1d1;"
                >Your Books</p>

                <!-- Book list -->
                {{#each items}}
                  <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                    style="margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #334155;"
                  >
                    <tr>
                      <!-- Book cover -->
                      <td
                        width="58"
                        style="vertical-align:top;padding-right:16px;"
                      >
                        <img
                          src="{{this.coverImage}}"
                          alt="{{this.title}}"
                          width="58"
                          style="display:block;width:58px;height:82px;object-fit:cover;border-radius:4px;"
                        />
                      </td>
                      <!-- Book info -->
                      <td style="vertical-align:top;">
                        <p
                          style="margin:0 0 4px;font-weight:600;color:#e6be77;"
                        >{{this.title}}</p>
                        <p
                          style="margin:0 0 6px;font-size:13px;color:#d1d1d1;"
                        >{{this.author}}</p>
                        <!-- Format badge — inline table to simulate inline-block -->
                        <table
                          cellpadding="0"
                          cellspacing="0"
                          border="0"
                          style="margin-bottom:6px;"
                        >
                          <tr>
                            <td
                              style="font-size:11px;font-weight:600;background-color:#3d1520;color:#e05470;border:1px solid #5a1e2e;padding:2px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:0.05em;"
                            >{{this.fileType}}</td>
                          </tr>
                        </table>
                        <p
                          style="margin:0;font-weight:700;color:#e6be77;"
                        >${{this.price}}</p>
                      </td>
                    </tr>
                  </table>
                {{/each}}

                <!-- Subtotal + discount (only if discount applied) -->
                {{#if hasDiscount}}
                  <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                    style="margin-top:12px;padding-top:12px;border-top:1px solid #334155;"
                  >
                    <tr>
                      <td style="font-size:14px;color:#d1d1d1;">Subtotal</td>
                      <td
                        align="right"
                        style="font-size:14px;color:#f8fafc;"
                      >${{subtotal}}</td>
                    </tr>
                  </table>
                  <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                    style="margin-top:12px;padding-top:12px;border-top:1px solid #334155;"
                  >
                    <tr>
                      <td style="font-size:14px;color:#d1d1d1;">Discount ({{couponCode}})</td>
                      <td
                        align="right"
                        style="font-size:14px;color:#14b8a6;"
                      >−${{discount}}</td>
                    </tr>
                  </table>
                {{/if}}

                <!-- Total -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="margin-top:20px;padding-top:16px;border-top:2px solid #d1d1d1;"
                >
                  <tr>
                    <td
                      style="font-size:16px;font-weight:600;color:#f8fafc;"
                    >Total Paid</td>
                    <td
                      align="right"
                      style="font-size:22px;font-weight:700;color:#e6be77;"
                    >${{total}}</td>
                  </tr>
                </table>

                <!-- CTA button -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="margin-top:24px;"
                >
                  <tr>
                    <td align="center">
                      <a
                        href="{{libraryUrl}}"
                        style="display:inline-block;background-color:#e6be77;color:#000000;padding:14px 32px;text-decoration:none;border-radius:8px;font-size:16px;font-weight:600;"
                      >Go to My Library</a>
                    </td>
                  </tr>
                  <tr>
                    <td
                      align="center"
                      style="padding-top:8px;font-size:13px;color:#d1d1d1;"
                    >
                      Your download links are available in your library at any
                      time.
                    </td>
                  </tr>
                </table>

              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="background-color:#0a1628;padding:20px;text-align:center;font-size:13px;color:#d1d1d1;"
              >
                <p style="margin:0 0 8px;">© 2026 Kun Bookshop. All rights
                  reserved.</p>
                <p style="margin:0;"><a
                    href="{{supportUrl}}"
                    style="color:#e6be77;text-decoration:none;"
                  >Contact Support</a></p>
              </td>
            </tr>

          </table>
          <!-- /Main container -->

        </td>
      </tr>
    </table>
    <!-- /Outer wrapper -->

  </body>
</html>